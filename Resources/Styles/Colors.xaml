<?xml version="1.0" encoding="utf-8" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">
    <!-- Colores base (no cambian con el tema) -->
    <Color x:Key="Primary">#512BD4</Color>
    <Color x:Key="Secondary">#DFD8F7</Color>

    <!-- Colores para Tema Claro -->
    <Color x:Key="PageBackgroundColor">#F5F5F5</Color>
    <Color x:Key="CardBackgroundColor">White</Color>
    <Color x:Key="PrimaryTextColor">#1E1E1E</Color>
    <Color x:Key="SecondaryTextColor">#757575</Color>

    <!-- Colores para Tema Oscuro (se sobrescriben abajo) -->
    <Color x:Key="PageBackgroundColorDark">#121212</Color>
    <Color x:Key="CardBackgroundColorDark">#1E1E1E</Color>
    <Color x:Key="PrimaryTextColorDark">White</Color>
    <Color x:Key="SecondaryTextColorDark">#AAAAAA</Color>
</ResourceDictionary>