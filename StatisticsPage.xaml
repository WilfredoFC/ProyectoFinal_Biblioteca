<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:ProyectoFinal_Biblioteca.Controls"
             x:Class="ProyectoFinal_Biblioteca.StatisticsPage">

    <ScrollView>
        <VerticalStackLayout Padding="15" Spacing="20">
            <Label Text="Estadísticas" Style="{StaticResource HeaderLabelStyle}"/>

            <!-- Gráfico Circular -->
            <Frame Style="{StaticResource CardFrameStyle}">
                <VerticalStackLayout>
                    <Label Text="Progreso de Lectura" Style="{StaticResource SubHeaderLabelStyle}"/>
                    <GraphicsView x:Name="PieChartView" HeightRequest="200">
                        <GraphicsView.Drawable>
                            <controls:PieChartDrawable x:Name="PieDrawable" />
                        </GraphicsView.Drawable>
                    </GraphicsView>
                </VerticalStackLayout>
            </Frame>

            <!-- Gráfico de Barras -->
            <Frame Style="{StaticResource CardFrameStyle}">
                <VerticalStackLayout>
                    <Label Text="Libros por Género" Style="{StaticResource SubHeaderLabelStyle}"/>
                    <GraphicsView x:Name="BarChartView" HeightRequest="250">
                        <GraphicsView.Drawable>
                            <controls:BarChartDrawable x:Name="BarDrawable" />
                        </GraphicsView.Drawable>
                    </GraphicsView>
                </VerticalStackLayout>
            </Frame>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>